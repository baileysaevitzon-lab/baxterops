# BaxterOps environment template — copy to .env.local for local dev, paste into Vercel
# Project Settings → Environment Variables for prod / preview.

# REQUIRED — Supabase public URL. Browser-safe.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# REQUIRED — Supabase publishable / anon key. Browser-safe.
# Use the "publishable" or "anon" key from Supabase Dashboard → Project Settings → API.
# DO NOT use the service_role key here. Service-role key NEVER goes in any NEXT_PUBLIC_* var.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# OPTIONAL — only set if you have a Vercel deployment with a different runtime URL
# (used by some MCP tools). Safe to leave blank for browser-only usage.
# NEXT_PUBLIC_SITE_URL=https://bmsbets.com
